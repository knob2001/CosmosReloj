<Window x:Class="CosmosReloj.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CosmosReloj"
        mc:Ignorable="d"
        Title="{Binding NombreVentana}"
        Height="340"
        Width="520"
        MinWidth="400"
        MinHeight="280"
        ResizeMode="CanResize"
        WindowStyle="None"
        BorderThickness="0"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" ResizeBorderThickness="6" UseAeroCaptionButtons="False" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <local:MainWindowVM/>
    </Window.DataContext>

    <Window.Resources>

        <local:StringToBrushConverter          x:Key="StringToBrushConverter"/>

        <!-- PALETA OSCURA COSMOS -->
        <SolidColorBrush x:Key="AppBg"           Color="#0D1117"/>
        <SolidColorBrush x:Key="PanelBg"         Color="#161B22"/>
        <SolidColorBrush x:Key="SurfaceBg"       Color="#1C2128"/>
        <SolidColorBrush x:Key="Border1"         Color="#21262D"/>
        <SolidColorBrush x:Key="Border2"         Color="#30363D"/>
        <SolidColorBrush x:Key="TextPrimary"     Color="#C9D1D9"/>
        <SolidColorBrush x:Key="TextSecondary"   Color="#8B949E"/>
        <SolidColorBrush x:Key="TextMuted"       Color="#484F58"/>
        <SolidColorBrush x:Key="AccentCyan"      Color="#58A6FF"/>
        <SolidColorBrush x:Key="AccentCyanDark"  Color="#1d3a6e"/>
        <SolidColorBrush x:Key="AccentCyanSurf"  Color="#162236"/>
        <SolidColorBrush x:Key="PlayGreen"       Color="#3FB950"/>
        <SolidColorBrush x:Key="PlayGreenDark"   Color="#238636"/>
        <SolidColorBrush x:Key="DangerRed"       Color="#c0392b"/>
        <SolidColorBrush x:Key="DangerRedSurf"   Color="#180E0E"/>
        <SolidColorBrush x:Key="DangerRedBorder" Color="#3a1414"/>
        <SolidColorBrush x:Key="AmberColor"      Color="#9a7000"/>
        <SolidColorBrush x:Key="AmberSurf"       Color="#17130A"/>
        <SolidColorBrush x:Key="AmberBorder"     Color="#3a2c00"/>

        <!-- BOTÓN STATUS BAR -->
        <Style x:Key="StatusBarButton" TargetType="{x:Type Button}">
            <Setter Property="Background"       Value="{StaticResource SurfaceBg}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Border1}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Foreground"       Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"         Value="10"/>
            <Setter Property="Height"           Value="20"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True"
                                Padding="6,0">
                            <Grid>
                                <Border x:Name="overlay" CornerRadius="3" Background="Transparent"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="overlay" Property="Background" Value="#22000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="overlay" Property="Background" Value="#44000000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- BOTÓN ACCIÓN PRINCIPAL -->
        <Style x:Key="AccionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background"      Value="{StaticResource AccentCyanSurf}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource AccentCyan}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground"      Value="{StaticResource AccentCyan}"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1d3a6e"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0d1a30"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- FONDO PRINCIPAL -->
    <Grid Background="{StaticResource AppBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.5*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Border Grid.Row="0" Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1"
                Padding="10,6"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" Source="../Resources/logo_rne.png"
                       Height="23" Width="71"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center"
                       ToolTip="Cosmos Reloj desarrollado por Servicios Exteriores"/>

                <TextBlock Grid.Column="1" Text="COSMOS RELOJ"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="14" FontWeight="Bold" FontFamily="Consolas"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Width="25" Height="20" Margin="0,0,4,0"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource StatusBarButton}"
                            ToolTip="Minimizar"
                            Click="BtnMinimizar_Click">
                        <Path Width="10" Height="2" Stretch="Uniform"
                              Fill="{StaticResource TextSecondary}"
                              Data="M0,0 L10,0"
                              Stroke="{StaticResource TextSecondary}"
                              StrokeThickness="1.5"/>
                    </Button>
                    <Button Width="25" Height="20" Margin="0,0,4,0"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource StatusBarButton}"
                            ToolTip="Maximizar"
                            Click="BtnMaximizar_Click">
                        <Path Width="10" Height="10" Stretch="Uniform"
                              Fill="{StaticResource TextSecondary}"
                              Data="M0,0 L10,0 L10,10 L0,10 Z"
                              Stroke="{StaticResource TextSecondary}"
                              StrokeThickness="1.5"/>
                    </Button>
                    <Button Width="25" Height="20"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource StatusBarButton}"
                            ToolTip="Cerrar"
                            Click="BtnCerrar_Click">
                        <Path Width="10" Height="10" Stretch="Uniform"
                              Fill="{StaticResource TextSecondary}"
                              Data="M0,0 L10,10 M10,0 L0,10"
                              Stroke="{StaticResource TextSecondary}"
                              StrokeThickness="1.5"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 0: CUENTAS ATRÁS -->
        <Grid Grid.Row="1" Background="{StaticResource AppBg}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Próxima hora -->
            <Border Grid.Column="0" BorderBrush="{StaticResource Border1}" BorderThickness="0,0,1,1" Padding="8">
                <Viewbox Stretch="Uniform">
                    <StackPanel Width="220" Height="70" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="PRÓXIMA HORA"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="13" FontFamily="Consolas" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding CuentaAtrasHora}"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="28" FontWeight="Bold"
                                   FontFamily="pack://application:,,,/Resources/#LCD AT&amp;T Phone Time/Date"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding HoraObjetivoTexto}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="13" FontFamily="Consolas"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Viewbox>
            </Border>

            <!-- Próxima media hora -->
            <Border Grid.Column="1" BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1" Padding="8">
                <Viewbox Stretch="Uniform">
                    <StackPanel Width="220" Height="70" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="PRÓXIMA MEDIA HORA"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="13" FontFamily="Consolas" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding CuentaAtrasMediaHora}"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="28" FontWeight="Bold"
                                   FontFamily="pack://application:,,,/Resources/#LCD AT&amp;T Phone Time/Date"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding MediaHoraObjetivoTexto}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="13" FontFamily="Consolas"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Viewbox>
            </Border>
        </Grid>

        <!-- ROW 1: RELOJ ACTUAL (span 2 columnas) -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{StaticResource AppBg}"
                BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1"
                Padding="4">
            <Viewbox Stretch="Uniform">
                <StackPanel Width="480" Height="120" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding HoraActual}"
                               Foreground="{Binding HoraActualColor, Converter={StaticResource StringToBrushConverter}}"
                               FontSize="94"
                               FontWeight="Bold"
                               FontFamily="pack://application:,,,/Resources/#LCD AT&amp;T Phone Time/Date"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding FechaActual}"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11" FontFamily="Consolas"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Viewbox>
        </Border>

        <!-- ROW 2: BOTÓN ACTUALIZAR (span 2 columnas) -->
        <Border Grid.Row="3" Grid.ColumnSpan="2" Background="{StaticResource AppBg}"
                Padding="16,8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button Command="{Binding ActualizarHoraCommand}"
                        IsEnabled="{Binding ActualizarEnabled}"
                        Style="{StaticResource AccionButtonStyle}"
                        ToolTip="Sincronizar hora con servidor NTP" Height="25">
                    <TextBlock Text="ACTUALIZAR HORA"
                               FontSize="13" FontFamily="Consolas" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- BARRA DE ESTADO -->
        <Border Grid.Row="4" Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource Border1}" BorderThickness="0,1,0,0"
                Height="24" Padding="12,0">
            <TextBlock Text="{Binding MensajeEstado}"
                       Foreground="{Binding MensajeEstadoColor, Converter={StaticResource StringToBrushConverter}}"
                       FontSize="10" FontFamily="Consolas"
                       VerticalAlignment="Center"/>
        </Border>

    </Grid>
</Window>
