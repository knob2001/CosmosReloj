<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>disable</Nullable>
    <PlatformTarget>x64</PlatformTarget>
    <Platforms>x64</Platforms>
    <Platform>x64</Platform>

    <RootNamespace>CosmosReloj</RootNamespace>
    <AssemblyName>CosmosReloj</AssemblyName>
    <StartupObject>CosmosReloj.App</StartupObject>

    <ApplicationIcon>Resources\logo_cosmos.ico</ApplicationIcon>
    <Title>COSMOS_RELOJ</Title>
    <Description>Reloj COSMOS</Description>
    <Company>Oscar</Company>
    <Product>CosmosReloj</Product>
    <Copyright>Copyright © 2026</Copyright>
    <Version>1.0.0.0</Version>
    <NoWarn>$(NoWarn);NU1701</NoWarn>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\LCDAT&amp;TPhoneTimeDate.ttf" />
    <Resource Include="Resources\logo_rne.png" />
  </ItemGroup>

</Project>
